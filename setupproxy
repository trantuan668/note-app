#!/bin/bash

clear
echo "=== AUTO INSTALL HTTP + SOCKS5 PROXY (3PROXY) ==="

read -p "Nhap username proxy: " PROXY_USER
read -p "Nhap password proxy: " PROXY_PASS
read -p "Nhap port HTTP (vd 8080): " HTTP_PORT
read -p "Nhap port SOCKS5 (vd 1080): " SOCKS_PORT

if [ -z "$PROXY_USER" ] || [ -z "$PROXY_PASS" ] || [ -z "$HTTP_PORT" ] || [ -z "$SOCKS_PORT" ]; then
    echo "Khong du thong tin. Thoat."
    exit 1
fi

echo "Dang cai dat..."
apt update -y
apt install git build-essential ufw -y

cd /opt
rm -rf 3proxy
git clone https://github.com/z3APA3A/3proxy.git
cd 3proxy
make -f Makefile.Linux

mkdir -p /etc/3proxy
mkdir -p /var/log/3proxy

cp src/3proxy /usr/local/bin/

cat <<EOF > /etc/3proxy/3proxy.cfg
daemon
maxconn 2000
nserver 8.8.8.8
nserver 1.1.1.1
nscache 65536
timeouts 1 5 30 60 180 1800 15 60

log /var/log/3proxy/3proxy.log
logformat "L%d-%m-%Y %H:%M:%S %E %U %C:%c %R:%r %O %I %h %T"

auth strong
users $PROXY_USER:CL:$PROXY_PASS
allow $PROXY_USER

proxy -p$HTTP_PORT
socks -p$SOCKS_PORT
EOF

ufw allow $HTTP_PORT
ufw allow $SOCKS_PORT

cat <<EOF > /etc/systemd/system/3proxy.service
[Unit]
Description=3Proxy Service
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/3proxy /etc/3proxy/3proxy.cfg
Restart=always

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable 3proxy
systemctl restart 3proxy

IP=$(curl -s ifconfig.me)

echo ""
echo "===== HOAN TAT ====="
echo "IP VPS: $IP"
echo ""
echo "HTTP Proxy:"
echo "$IP:$HTTP_PORT"
echo "User: $PROXY_USER"
echo "Pass: $PROXY_PASS"
echo ""
echo "SOCKS5 Proxy:"
echo "$IP:$SOCKS_PORT"
echo "User: $PROXY_USER"
echo "Pass: $PROXY_PASS"
echo ""
echo "Kiem tra trang thai:"
echo "systemctl status 3proxy"
