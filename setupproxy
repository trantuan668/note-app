#!/bin/bash

clear
echo "=== AUTO INSTALL HTTP + SOCKS5 PROXY (DOCKER) ==="

read -p "Nhap username: " USER
read -p "Nhap password: " PASS
read -p "Nhap port HTTP (vd 8080): " HTTP_PORT
read -p "Nhap port SOCKS5 (vd 1080): " SOCKS_PORT

if [ -z "$USER" ] || [ -z "$PASS" ] || [ -z "$HTTP_PORT" ] || [ -z "$SOCKS_PORT" ]; then
    echo "Thieu thong tin. Thoat."
    exit 1
fi

echo "Dang cai Docker..."
apt update -y
apt install -y docker.io curl ufw

systemctl enable docker
systemctl start docker

echo "Mo firewall..."
ufw allow $HTTP_PORT
ufw allow $SOCKS_PORT

echo "Xoa container cu neu co..."
docker rm -f http-proxy socks-proxy 2>/dev/null

echo "Chay HTTP Proxy..."
docker run -d \
--name http-proxy \
-p $HTTP_PORT:3128 \
-e PROXY_USERNAME=$USER \
-e PROXY_PASSWORD=$PASS \
vimagick/tinyproxy

echo "Chay SOCKS5 Proxy..."
docker run -d \
--name socks-proxy \
-p $SOCKS_PORT:1080 \
-e PROXY_USER=$USER \
-e PROXY_PASSWORD=$PASS \
serjs/go-socks5-proxy

IP=$(curl -s ifconfig.me)

echo ""
echo "===== HOAN TAT ====="
echo "IP VPS: $IP"
echo ""
echo "HTTP Proxy:"
echo "$IP:$HTTP_PORT"
echo "User: $USER"
echo "Pass: $PASS"
echo ""
echo "SOCKS5 Proxy:"
echo "$IP:$SOCKS_PORT"
echo "User: $USER"
echo "Pass: $PASS"
echo ""
echo "Kiem tra container:"
echo "docker ps"
